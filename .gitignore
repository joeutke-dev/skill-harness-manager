# Dependencies
node_modules/

# Build output — built by CI on tag push and uploaded to the GitHub release,
# not committed (Obsidian sample-plugin convention).
main.js
*.js.map

# Logs
npm-debug.log*

# Editor / OS
.DS_Store
*.swp

# Per-install plugin state (Obsidian writes this at runtime)
data.json

