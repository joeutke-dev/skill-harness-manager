# Dependencies — the only thing excluded. Built artifacts (main.js, styles.css,
# manifest.json) ARE committed so the folder can be copied straight into
# .obsidian/plugins/skill-layer/ and loaded.
node_modules/

# Logs
npm-debug.log*

# Editor / OS
.DS_Store
*.swp

# Per-install plugin state (Obsidian writes this at runtime)
data.json

# Smoke-test transpile output (regenerated by `npm run smoke`)
test/.built/
